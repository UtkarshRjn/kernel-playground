# Web app (apps/web) — copy to .env.local and fill in.

# Postgres (Phase 1)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kernel_playground"

# Auth.js (Phase 1)
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Execution backend callback (Phase 1)
EXECUTION_API_URL="http://localhost:8000"
EXECUTION_CALLBACK_SECRET="shared-hmac-secret"
