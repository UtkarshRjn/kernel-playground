# Web app (apps/web) — copy to .env.local and fill in.

# Postgres (Phase 1)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kernel_playground"

# Auth.js (Phase 1)
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Execution backend (Modal HTTP endpoint). When both are set, the run pipeline uses
# real GPUs; otherwise it falls back to the deterministic mock provider.
EXECUTION_API_URL="https://<your-workspace>--kernel-playground-execution-web.modal.run"
EXECUTION_TOKEN="the KP_EXEC_TOKEN you set in the kp-exec-secret Modal secret"
