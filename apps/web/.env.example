# ---- Database (Postgres) ----
# Neon/Supabase pooled connection string for the app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection for migrations (Neon/Supabase). Optional but recommended:
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- Auth.js ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Set to your deployed URL in production (e.g. https://your-app.vercel.app)
AUTH_URL="http://localhost:3000"
# GitHub OAuth app (Settings → Developer settings → OAuth Apps)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
# Google OAuth client (Google Cloud Console → Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- Analytics (PostHog) ----
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ---- Execution backend (Modal HTTP endpoint) ----
# When both are set the run pipeline uses real GPUs; otherwise the deterministic mock.
EXECUTION_API_URL=""
EXECUTION_TOKEN=""
